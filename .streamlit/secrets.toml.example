# =============================================================================
# Quant Portfolio-Kaizen — secrets template (DO NOT commit a filled copy).
# =============================================================================
# On Streamlit Community Cloud:
#   1. Deploy the app, open it, click "⋮" > "Settings" > "Secrets".
#   2. Paste the content of this file with real values.
#   3. Save. Streamlit re-runs the app with secrets injected at runtime.
#
# On a self-hosted container (Docker/Render/Fly):
#   Copy this file to `.streamlit/secrets.toml` next to the app code and fill
#   the values. The .gitignore at the repo root already excludes secrets.toml.
# =============================================================================

# -------------------------------------------------------------------
# Authentication / user accounts
# -------------------------------------------------------------------
[auth]
# Visible cookie name (any string).
cookie_name = "qpk_auth"

# Signing key for the JWT cookie. MUST be 32+ random characters.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(48))"
cookie_key = "REPLACE_WITH_32_PLUS_RANDOM_CHARS_FROM_secrets.token_urlsafe"

# Cookie lifetime in days. Short-lived = more secure (forces re-login).
cookie_expiry_days = 1

# Optional: emails allowed to self-register (most deployments leave this empty).
preauthorized = []

# -------------------------------------------------------------------
# Users (one entry per account). Keys are usernames (lower-cased on read).
# -------------------------------------------------------------------
# Generate a password hash with:
#   python scripts/hash_password.py
# and paste the resulting `$2b$...` string under `password_hash`.
#
# Role values:
#   admin    -> full app, including Advanced Research and Data Freshness ops.
#   analyst  -> Overview, Allocation, Research Strategy, Price Path, Risk,
#               Validation, Market Regime, Options, Fundamentals, Data Freshness.
#   viewer   -> Overview, Allocation, Price Path only (read-only).
# -------------------------------------------------------------------
[auth.users.chris]
name          = "Chris"
email         = "chris@example.com"
password_hash = "$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH"
role          = "admin"

[auth.users.analyst1]
name          = "Senior Analyst"
email         = "analyst1@example.com"
password_hash = "$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH"
role          = "analyst"

[auth.users.viewer1]
name          = "Read-Only User"
email         = "viewer1@example.com"
password_hash = "$2b$12$REPLACE_WITH_REAL_BCRYPT_HASH"
role          = "viewer"

# -------------------------------------------------------------------
# Backend data sources (all optional — the app degrades gracefully without them).
# -------------------------------------------------------------------
BANXICO_TOKEN     = ""
SEC_USER_AGENT    = "YourCompany/1.0 contact@yourdomain.com"

# -------------------------------------------------------------------
# Supabase (optional, for persisting model registry / runs).
# The app accepts either the lowercase aliases below or root-level
# SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY entries.
# -------------------------------------------------------------------
[supabase]
url         = ""
service_key = ""
